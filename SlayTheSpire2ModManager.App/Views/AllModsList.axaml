<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SlayTheSpire2ModManager.App.ViewModels"
             xmlns:models="using:SlayTheSpire2ModManager.App.Models"
             xmlns:converters="using:SlayTheSpire2ModManager.App.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SlayTheSpire2ModManager.App.AllModsList"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </UserControl.Resources>

    <Grid ColumnDefinitions="540,Auto,*">
        <ScrollViewer Grid.Column="0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Grid RowDefinitions="Auto,*"
                  MinWidth="360">
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            Margin="4">
                    <Button Click="OnInstallModClick">安装模组</Button>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ModMetadataListCollection}"
                          SelectedItem="{Binding SelectedMod, Mode=TwoWay}"
                          SelectionMode="Single"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="启用?" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:GameModMetadata">
                                    <CheckBox HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Mod 名称" Binding="{Binding Name}" Width="180" />
                        <DataGridTextColumn Header="包名" Binding="{Binding PckName}" Width="140" />
                        <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="100" />
                        <DataGridTextColumn Header="作者" Binding="{Binding Author}" Width="180" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </ScrollViewer>

        <GridSplitter Grid.Column="1"
                      ResizeDirection="Columns"
                      Background="Gainsboro"
                      Cursor="SizeWestEast" />

        <Border Grid.Column="2"
                Padding="8">
            <Grid>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding IsModSelected}">
                    <StackPanel Spacing="6"
                                HorizontalAlignment="Stretch">
                        <TextBlock FontWeight="Bold" FontSize="16" Text="{Binding SelectedMod.Name}" />
                        <TextBlock Text="{Binding SelectedMod.PckName, StringFormat=包名: {0}}" />
                        <TextBlock Text="{Binding SelectedMod.Version, StringFormat=版本: {0}}" />
                        <TextBlock Text="{Binding SelectedMod.Author, StringFormat=作者: {0}}" />
                        <TextBlock Text="操作:" FontWeight="SemiBold" />
                        <CheckBox Content="启用该模组"
                                  IsChecked="{Binding SelectedMod.IsEnabled, Mode=TwoWay}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Margin="2"
                                    Background="IndianRed"
                                    Click="OnDeleteSelectedModClick">删除</Button>

                        </StackPanel>

                        <TextBlock Text="描述:" FontWeight="SemiBold" />
                        <TextBlock TextWrapping="Wrap"
                                   Text="{Binding SelectedMod.Description, TargetNullValue=暂无描述}" />
                    </StackPanel>
                </ScrollViewer>

                <TextBlock IsVisible="{Binding IsModSelected, Converter={StaticResource InverseBooleanConverter}}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="请选择模组！" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
